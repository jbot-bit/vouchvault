# Copy to .env for local runs. On Replit these go in the workspace AND the
# Deployment's Secrets tab (the two are separate — missing secrets on the
# Deployment side is the #1 cause of "works locally but 500s live").

# -------- Required --------

# Postgres connection string. The Replit Postgres integration sets this
# automatically in the workspace; mirror it into the Deployment's secrets.
DATABASE_URL=postgresql://user:pass@host:5432/vouchvault

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs the bot is allowed to serve.
# Get a group's chat ID by adding the bot to it and hitting
# https://api.telegram.org/bot<TOKEN>/getUpdates — it'll be negative for groups.
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# Comma-separated Telegram user IDs that can run admin-only commands.
TELEGRAM_ADMIN_IDS=123456789

# Secret string Telegram will send in the x-telegram-bot-api-secret-token
# header on every webhook request. Generate a random value and set the
# webhook with `npm run telegram:webhook`. If this is set, server.ts
# rejects any webhook request whose header doesn't match.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Public base URL your bot is reachable at, WITHOUT trailing slash.
# Used by `npm run telegram:webhook` when registering the webhook URL.
# On Replit, grab it from the Deploy page after the first deploy.
PUBLIC_BASE_URL=https://your-deploy.replit.app

# -------- Optional --------

# Your bot's @username (without the @). Some onboarding surfaces embed it
# in user-facing text; if omitted, the bot looks it up via getMe at boot.
# TELEGRAM_BOT_USERNAME=SEQmodbot

# HTTP port. Replit forwards external :80 → local :5000 already; override
# only if you're running it somewhere else.
# PORT=5000
