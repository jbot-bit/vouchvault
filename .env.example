# Copy to .env for local runs. On Railway these go in the bot service's
# Variables tab (Project → Service → Environment). DATABASE_URL is wired
# from the Postgres service via the `${{Postgres.DATABASE_URL}}` reference.

# -------- Required --------

# Postgres connection string. On Railway, set as
# `${{Postgres.DATABASE_URL}}` so it tracks the Postgres service.
DATABASE_URL=postgresql://user:pass@host:5432/vouchvault

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs the bot is allowed to serve.
# Get a group's chat ID by adding the bot to it and hitting
# https://api.telegram.org/bot<TOKEN>/getUpdates — it'll be negative for groups.
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# Comma-separated Telegram user IDs that can run admin-only commands.
TELEGRAM_ADMIN_IDS=123456789

# Secret string Telegram will send in the x-telegram-bot-api-secret-token
# header on every webhook request. Generate a random value
# (e.g. `openssl rand -hex 32`) and set the webhook with
# `npm run telegram:webhook`. If this is set, server.ts rejects any
# webhook request whose header doesn't match.
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Public base URL your bot is reachable at, WITHOUT trailing slash.
# Used by `npm run telegram:webhook` when registering the webhook URL.
# On Railway, generate the domain in Service Settings → Networking and
# paste the *.up.railway.app URL here.
PUBLIC_BASE_URL=https://your-service.up.railway.app

# -------- Optional --------

# Your bot's @username (without the @). Some onboarding surfaces embed it
# in user-facing text; if omitted, the bot looks it up via getMe at boot.
# TELEGRAM_BOT_USERNAME=SEQmodbot

# Comma-separated list of @usernames whose legacy export messages should
# be skipped at the export-sender layer (i.e. the bot's own posts in the
# old group). Read by replayLegacyTelegramExport.
# LEGACY_BOT_SENDERS=

# pino log level: trace | debug | info | warn | error | fatal. Defaults
# to "info" if unset.
# LOG_LEVEL=info

# Production / development flag, mainly for downstream libraries.
NODE_ENV=production

# HTTP port. Railway forwards the public domain → the service's PORT
# automatically; override only for local runs.
# PORT=5000

# -------- v6 channel relay (V3.5.4) --------

# Telegram channel id where the ingest bot publishes vouches. Telegram-
# native channel-discussion link auto-forwards into the supergroup's
# General topic. Negative numeric id (e.g. -1003xxxxxxxxx). Required
# only when VV_RELAY_ENABLED=true.
# TELEGRAM_CHANNEL_ID=

# Toggle for the channel-relay publish path. When true, ingest publishes
# to TELEGRAM_CHANNEL_ID and captures the auto-forward into the
# supergroup. When false (default), the V3 direct-supergroup publish
# path is used. Set true only after verifying the channel-discussion
# link works manually (post a test message in the channel and confirm
# it auto-forwards).
# VV_RELAY_ENABLED=false

# -------- v6 multi-bot stack (V3.5.5) --------

# Optional. When set, /webhooks/telegram/lookup routes inbound updates
# to the lookup bot (read-only /search, /recent). When unset, the
# ingest bot dual-registers these commands as fallback.
# TELEGRAM_LOOKUP_TOKEN=

# Optional. When set, /webhooks/telegram/admin routes inbound updates
# to the admin bot (admin commands + chat-moderation). When set, the
# ingest bot skips moderation (admin bot owns it). When unset, ingest
# moderates as today.
# TELEGRAM_ADMIN_TOKEN=

# Comma-separated Telegram user IDs allowed to invoke admin bot
# commands. Defaults to TELEGRAM_ADMIN_IDS if unset.
# TELEGRAM_ADMIN_USER_IDS=
