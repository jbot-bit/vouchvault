{
  "name": "vouchvault",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm test",
    "start": "node --experimental-strip-types src/server.ts",
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "test": "node --test --experimental-strip-types src/mastra/archiveUx.test.ts src/mastra/legacyImport.test.ts src/telegramBotInput.test.ts",
    "format": "prettier --write .",
    "check:format": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types scripts/runMigrations.ts",
    "db:init": "node --experimental-strip-types scripts/initDatabase.ts",
    "telegram:onboarding": "node --experimental-strip-types scripts/configureTelegramOnboarding.ts",
    "telegram:webhook": "node --experimental-strip-types scripts/setTelegramWebhook.ts",
    "replay:legacy": "node --experimental-strip-types scripts/replayLegacyTelegramExport.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "0.31.4",
    "prettier": "3.3.3",
    "typescript": "latest"
  }
}
